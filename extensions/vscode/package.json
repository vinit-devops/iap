{
  "name": "iap-vscode",
  "displayName": "IaP",
  "description": "Infrastructure as Prompt (IaP) language support: syntax registration and Language Server Protocol client (diagnostics, completion, hover, navigation, rename, code actions, architecture preview).",
  "version": "1.0.0",
  "publisher": "infraasprompt",
  "license": "Apache-2.0",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinit-devops/iap.git"
  },
  "homepage": "https://github.com/vinit-devops/iap#readme",
  "bugs": {
    "url": "https://github.com/vinit-devops/iap/issues"
  },
  "keywords": [
    "iap",
    "infrastructure",
    "infrastructure-as-code",
    "yaml",
    "lsp",
    "language-server",
    "devops",
    "cloud"
  ],
  "galleryBanner": {
    "color": "#1e293b",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "main": "./extension.bundled.js",
  "activationEvents": [
    "onLanguage:iap"
  ],
  "contributes": {
    "languages": [
      {
        "id": "iap",
        "aliases": [
          "IaP"
        ],
        "extensions": [
          ".iap.yaml",
          ".iap.yml",
          ".iap-map.yaml"
        ],
        "filenames": [
          "infrastructure.iap.yaml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "IaP",
      "properties": {
        "iap.languageServer.path": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path to an alternative iap-language-server executable. Leave empty to use the server bundled inside the extension (server/server.js), which is the default and requires no configuration. This is an escape hatch for development; it is not required."
        },
        "iap.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace the communication between VS Code and the IaP language server."
        }
      }
    },
    "commands": [
      {
        "command": "iap.restartServer",
        "title": "IaP: Restart Language Server"
      },
      {
        "command": "iap.showPreview",
        "title": "IaP: Show Architecture Preview"
      }
    ]
  },
  "scripts": {
    "build:vsix": "node build-vsix.mjs",
    "smoke": "node build-vsix.mjs && node smoke.mjs",
    "package:vsce": "npx --yes @vscode/vsce package --no-dependencies",
    "publish:marketplace": "npx --yes @vscode/vsce publish --no-dependencies",
    "publish:openvsx": "npx --yes ovsx publish"
  },
  "dependencies": {
    "@iap/language-server": "workspace:*",
    "vscode-languageclient": "^9.0.1"
  }
}
