{
  "name": "@iap/provider-aws",
  "version": "0.1.0",
  "description": "AWS reference provider package for IaP (spec ch. 12, IEP-0012): core-level certification — fail-closed mappings for the production-slice kinds, extension schema, attestation functions, and conformance cases",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "manifest.json",
    "mappings",
    "schema",
    "conformance"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@iap/model": "workspace:*",
    "@iap/parser": "workspace:*",
    "@iap/provider-sdk": "workspace:*",
    "ajv": "^8.17.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "typescript": "^5.7.0"
  }
}
