{
  "name": "@iap/mcp-server",
  "version": "0.1.0",
  "description": "The IaP MCP server (spec ch. 19/ch. 23; roadmap Phase 13): a read-only tool registry exposing authoring and analysis tools (author, validate, cost, security, compliance) over the reference engines, with NO deployment or mutation tools — assistant tools structurally cannot call provider APIs. Every authoring result carries per-field provenance.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "iap-mcp-server": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./transport": {
      "types": "./dist/transport.d.ts",
      "default": "./dist/transport.js"
    },
    "./bin": {
      "types": "./dist/bin.d.ts",
      "default": "./dist/bin.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@iap/compliance": "workspace:*",
    "@iap/cost": "workspace:*",
    "@iap/intent-compiler": "workspace:*",
    "@iap/model": "workspace:*",
    "@iap/security": "workspace:*",
    "@iap/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "typescript": "^5.7.0"
  }
}
