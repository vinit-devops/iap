{
  "name": "@iap/language-server",
  "version": "0.1.0",
  "description": "Infrastructure language server for the Infrastructure as Prompt (IaP): schema-derived diagnostics, completion, hover, navigation, rename, code actions, and the iap/preview architecture extension (spec ch. 23)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "iap-language-server": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "license": "SEE LICENSE (TBD)",
  "dependencies": {
    "@iap/architecture": "workspace:*",
    "@iap/model": "workspace:*",
    "@iap/parser": "workspace:*",
    "@iap/policy": "workspace:*",
    "@iap/sdk": "workspace:*",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "typescript": "^5.7.0"
  }
}
